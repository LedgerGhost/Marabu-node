# LedgerGhost Marabu Node environment example.
# Copy this file to .env for local use if your runner loads dotenv files.
# Bun does not automatically load this file for every command, so exporting
# these variables in the shell or defining them in PM2/systemd is also valid.

# Server binding.
# Use 127.0.0.1 for local-only development.
# Use 0.0.0.0 when the node must accept external TCP connections.
SERVER_HOST=127.0.0.1
SERVER_PORT=18018

# Node identity advertised in hello messages and logs.
AGENT_NAME=LedgerGhost
AGENT_VERSION=1.0.0
AGENT_AUTHOR="Your Name"

# Peer discovery and connection management.
# Leave BOOTSTRAP_PEERS empty for isolated local runs.
# For the NTUA class network, either omit BOOTSTRAP_PEERS to use the defaults
# from src/conf.ts or set it to the instructor-provided host:port list.
IP_RETRIEVAL_SERVICE=https://ifconfig.me/ip
TARGET_NUM_CONNECTIONS=0
PEERS_FILE=peers.json
BOOTSTRAP_PEERS=
MAX_PEERS_PER_NEIGHBOUR=8

# Logging.
# Common values: trace, debug, info, warn, error.
LOG_LEVEL=info

# Mining.
# Keep disabled unless intentionally mining for the class network.
MINING_ENABLED=false
MINER_STUDENT_IDS=
MINER_REWARD_PUBKEY=
MINER_NOTE=
MINER_MINE_EMPTY_BLOCKS=false
MINER_WORKERS=0
MINER_BATCH_SIZE=5000
MINER_TEMPLATE_REFRESH_MS=15000
MINER_STATUS_INTERVAL_MS=5000
MINER_NONCE_HEX_CHARS=64
